{
  "name": "kbase",
  "version": "0.1.0",
  "description": "Codebase knowledge layer for AI coding agents",
  "type": "module",
  "bin": {
    "kb": "./dist/cli/index.js",
    "kb-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:mcp": "node dist/mcp/server.js",
    "start:cli": "node dist/cli/index.js"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "mcp",
    "coding-agent",
    "knowledge-base",
    "comprehension-debt"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "commander": "latest",
    "fast-glob": "latest",
    "gray-matter": "latest",
    "uuid": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0"
  }
}
